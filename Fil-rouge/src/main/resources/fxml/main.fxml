<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.filrouge.controller.MainController"
            stylesheets="@/style.css">

    <top>
        <VBox>
            <HBox styleClass="header" spacing="8" style="-fx-alignment: CENTER_LEFT;">
                <Label text="SOCIAL " styleClass="app-title"/>
                <Label text="PUBLISHER" styleClass="app-title-accent"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statTotal"     text="0 publications" styleClass="stat-total"/>
                <Label text=" · " style="-fx-text-fill: #cccccc;"/>
                <Label fx:id="statValides"   text="0 valides"      styleClass="stat-valid"/>
                <Label text=" · " style="-fx-text-fill: #cccccc;"/>
                <Label fx:id="statInvalides" text="0 invalides"    styleClass="stat-invalid"/>
            </HBox>

            <HBox styleClass="filter-bar" spacing="10" style="-fx-alignment: CENTER_LEFT;">
                <TextField fx:id="searchField"
                           promptText="Rechercher par auteur, type..."
                           styleClass="search-field"
                           onKeyReleased="#handleRecherche"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnFiltreAll"   text="Tous"  styleClass="filter-btn-active" onAction="#handleFiltreAll"/>
                <Button fx:id="btnFiltreTexte" text="Texte" styleClass="filter-btn"        onAction="#handleFiltreTexte"/>
                <Button fx:id="btnFiltreMedia" text="Média" styleClass="filter-btn"        onAction="#handleFiltreMedia"/>
            </HBox>

            <HBox styleClass="action-bar" spacing="8" style="-fx-alignment: CENTER_LEFT;">
                <ComboBox fx:id="typeCombo" promptText="Choisir un type"/>
                <Button text="+ Ajouter"  styleClass="btn-primary" onAction="#handleAjouter"/>
                <Button text="Modifier"   styleClass="btn-edit"    onAction="#handleModifier"/>
                <Button text="Supprimer"  styleClass="btn-delete"  onAction="#handleSupprimer"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↺" styleClass="btn-refresh" onAction="#handleRafraichir"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane orientation="HORIZONTAL" dividerPositions="0.65">
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"     text="ID"     prefWidth="55"/>
                    <TableColumn fx:id="colType"   text="TYPE"   prefWidth="160"/>
                    <TableColumn fx:id="colAuteur" text="AUTEUR" prefWidth="130"/>
                    <TableColumn fx:id="colDate"   text="DATE"   prefWidth="185"/>
                    <TableColumn fx:id="colValide" text="STATUT" prefWidth="100"/>
                </columns>
            </TableView>

            <VBox styleClass="detail-pane" spacing="12">
                <Label text="DÉTAILS" styleClass="detail-title"/>
                <TextArea fx:id="detailArea" editable="false"
                          VBox.vgrow="ALWAYS" wrapText="true"/>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Prêt"
               styleClass="status-bar" maxWidth="Infinity"/>
    </bottom>

</BorderPane>